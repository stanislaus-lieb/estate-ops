# Copy to .env for local development. .env files are ignored by git.
# Never commit real database passwords or provider secrets.

ESTATEOPS_DB_HOST=localhost
ESTATEOPS_DB_PORT=5432
ESTATEOPS_DB_NAME=estateops
ESTATEOPS_DB_MAINTENANCE_DATABASE=postgres
ESTATEOPS_DB_USERNAME=estateops
ESTATEOPS_DB_PASSWORD=
ESTATEOPS_DB_SSL_MODE=Prefer
ESTATEOPS_DB_GSS_ENCRYPTION_MODE=Disable
