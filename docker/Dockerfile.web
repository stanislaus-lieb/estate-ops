# syntax=docker/dockerfile:1

FROM node:24-alpine AS build
WORKDIR /app

COPY src/EstateOps.Web/package*.json ./
RUN npm ci

COPY src/EstateOps.Web/ .
RUN npm run build

FROM nginx:1.29-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist/estateops-web/browser /usr/share/nginx/html
EXPOSE 80
